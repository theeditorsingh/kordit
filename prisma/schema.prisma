generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  password      String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Kordit Relations
  ownedBoards Board[] @relation("BoardOwner")
  memberships Member[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Kordit Models
model Board {
  id         String   @id @default(cuid())
  title      String
  slug       String
  color      String   @default("#0052CC")
  visibility String   @default("Workspace") // Private, Workspace, Public
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ownerId String
  owner   User   @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  columns Column[]
  cards   Card[]
  members Member[]

  @@unique([ownerId, slug])
}

model Column {
  id        String   @id @default(cuid())
  title     String
  color     String   @default("#0052CC")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  cards Card[]
}

model Card {
  id          String    @id @default(cuid())
  title       String
  description String    @default("")
  priority    String    @default("medium") // urgent, high, medium, low
  dueDate     DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  boardId  String
  board    Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  
  columnId String
  column   Column @relation(fields: [columnId], references: [id], onDelete: Cascade)

  // In a real app, you'd map labels, checklists, and assignees to separate tables
  // For simplicity right now, we can use JSON if using PostgreSQL
  labels      Json @default("[]")
  checklist   Json @default("[]")
  assigneeIds Json @default("[]")
}

model Member {
  id        String   @id @default(cuid())
  role      String   @default("Member") // Admin, Member
  createdAt DateTime @default(now())

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}
